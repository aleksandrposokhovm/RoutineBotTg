# RoutineBot Environment Variables
# Получи BOT_TOKEN у @BotFather в Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Google Gemini API Keys (можно указать несколько ключей через запятую для авторотации: KEY1,KEY2,KEY3...)
# Поддерживается любое количество ключей, их можно добавлять/удалять динамически без перезапуска бота
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_1,YOUR_GEMINI_API_KEY_2

# SQLite (по умолчанию)
DATABASE_URL="file:./prisma/dev.db"

# Твой Telegram User ID (получи у @userinfobot)
OWNER_TG_ID=YOUR_TELEGRAM_ID_HERE

# Список разрешенных пользователей (их Telegram ID, через запятую). Оставь пустым, чтобы разрешить доступ ТОЛЬКО владельцу.
ALLOWED_TG_IDS=

# Часовой пояс по умолчанию
DEFAULT_TIMEZONE=Asia/Yekaterinburg

# URL фронтенда (для CORS и Mini App)
FRONTEND_URL=http://localhost:5173

# Порт бэкенда
PORT=3001

# Google OAuth 2.0 Credentials (Календарь и Таблицы)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

